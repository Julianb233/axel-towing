# ============================================
# Axle Towing Website — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.

# --- Railway / Hosting ---
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production

# --- Supabase (dispatch request storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (dispatch email notifications) ---
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Twilio (dispatch SMS notifications) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
DISPATCH_PHONE_NUMBER=+14802885526

# --- Google reCAPTCHA v3 (spam protection) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# --- Google Analytics 4 ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Google Tag Manager (optional) ---
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- Google Search Console verification ---
NEXT_PUBLIC_GSC_VERIFICATION=your-gsc-verification-code

# --- GoHighLevel CRM (lead pipeline sync) ---
GHL_API_KEY=your-ghl-location-api-key
GHL_LOCATION_ID=your-ghl-location-id
GHL_PIPELINE_ID=your-pipeline-id
GHL_STAGE_NEW_LEAD_ID=your-new-lead-stage-id
# Chat widget: get from GHL > Sites > Chat Widget > Embed Code > data-widget-id
NEXT_PUBLIC_GHL_CHAT_WIDGET_ID=your-ghl-chat-widget-id
# Optional webhook fallback: GHL > Automation > Webhooks > Create Inbound Webhook
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID

# --- Domain ---
NEXT_PUBLIC_SITE_URL=https://axletowing.com
