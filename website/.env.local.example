# ============================================
# Axle Towing Website — .env.local Example
# ============================================
# Copy this file to .env.local for local development.
# See .env.example for the full catalog of supported variables.

# --- GoHighLevel Chat Widget ---
# Get the widget id from GHL dashboard:
#   Sites > Chat Widget > Embed Code > data-widget-id
# TODO: replace with real widget id once Axle's GHL chat widget is configured.
# Leave empty to disable the widget (the component returns null when unset).
NEXT_PUBLIC_GHL_CHAT_WIDGET_ID=

# --- GoHighLevel CRM (lead pipeline sync) ---
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
GHL_STAGE_NEW_LEAD_ID=
GHL_WEBHOOK_URL=
