# ============================================
# Axle Towing Dashboard — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.

# --- Vercel (deployment) ---
VERCEL_OIDC_TOKEN=

# --- Anthropic (chatbot) ---
ANTHROPIC_API_KEY=sk-ant-xxxx

# --- Supabase (data storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Gemini (optional AI features) ---
GEMINI_API_KEY=

# --- Linear (PPP chat -> Linear ticket creation) ---
# Used by app/api/chat/route.ts createLinearIssue.
# Hardcoded fallbacks ship in code, so these are optional.
LINEAR_API_KEY=lin_api_xxxx
LINEAR_TEAM_ID=9a9d11aa-c8a5-4dc5-855c-c1da260db615
# Axel Towing - SEO + Automation project (AI-9180)
LINEAR_PROJECT_ID=8c1e1d4c-9a6c-4759-99fa-91c6c61ec113
