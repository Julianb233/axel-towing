# ============================================
# Axle Towing Website — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.

# --- Railway / Hosting ---
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production

# --- Supabase (dispatch request storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (dispatch email notifications) ---
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Twilio (dispatch SMS notifications) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
DISPATCH_PHONE_NUMBER=+14802885526

# --- Google reCAPTCHA v3 (spam protection) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# --- Domain ---
NEXT_PUBLIC_SITE_URL=https://axletowing.com
